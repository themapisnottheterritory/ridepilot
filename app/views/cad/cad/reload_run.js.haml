- if @run
  var infoPopupOpen = map.hasLayer(infoPopup); // check if popup was open
  removeVehicle(#{@run.id});
  var vehicle_loc = #{@vehicle_location_data.to_json.try(:html_safe) || {}};
  drawVehicle(vehicle_loc, infoPopupOpen);

= render 'render_run_stops'
= render 'render_prior_path'
= render 'render_upcoming_path'
